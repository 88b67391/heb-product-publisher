# HEB aaPanel 开站配置 — 勿放在 plugins/ 目录内（插件更新会删除）
#
# 首次在服务器执行：
#   sudo bash heb-aapanel.sh init-env
#   sudo nano /etc/heb-aapanel.env
#
# 或自定义路径：export HEB_AAPANEL_ENV=/root/heb-aapanel.env

# aaPanel 网站根目录
WWW_ROOT="/www/wwwroot"

# 主站（Hub）域名目录名
MAIN_DOMAIN="www.hongbotex.com"

# 主站完整 URL（用于 prep 模式 search-replace）
MAIN_URL="https://www.hongbotex.com"

# MySQL（aaPanel 默认 localhost；若不同请改）
DB_HOST="localhost"

# WordPress 表前缀
TABLE_PREFIX="wp_"

# 新开语言站 WP 管理员（fresh 模式安装用；prep --sync-admin 也会用）
WP_ADMIN_USER="admin"
WP_ADMIN_EMAIL="admin@hongbotex.com"
# 留空则 fresh 随机生成；prep 需配合 --sync-admin 才会改密码
# 含 $ & ! 等字符时必须用单引号，勿用双引号（否则 $9 会被 bash 展开报错）
WP_ADMIN_PASS=''

# 所有语言站共用的 Receiver secret（与主站「远端站点列表」一致）
# 留空则脚本随机生成并打印
HEB_RECEIVER_SECRET=''

# 主站 Hub 后台地址（脚本结束时提示用）
HUB_URL="https://www.hongbotex.com/wp-admin"

# PHP / WP-CLI（留空自动探测 aaPanel 路径）
PHP_BIN=""
WP_CLI=""

# 语言站列表（prep-all 批量用）：子域名:WP_locale
LANG_SITES=(
	"ar.hongbotex.com:ar"
	"fr.hongbotex.com:fr_FR"
	"ja.hongbotex.com:ja_JP"
	"ko.hongbotex.com:ko_KR"
	"ru.hongbotex.com:ru_RU"
	"vi.hongbotex.com:vi"
)
